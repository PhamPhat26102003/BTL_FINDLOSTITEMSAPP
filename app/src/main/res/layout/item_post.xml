<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="4dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="4dp"
    android:backgroundTint="#EEC2FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Hình ảnh và tag "Tin nổi bật" -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/imagePost"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:src="@drawable/minhhoa" />

            <TextView
                android:id="@+id/tagHighlight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tin nổi bật"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_highlight_tag"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textSize="12sp"
                android:layout_alignParentEnd="true"
                android:layout_margin="8dp" />
        </RelativeLayout>

        <!-- Lượt xem + tiêu đề -->
        <TextView
            android:id="@+id/tvViews"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👁 1 lượt xem"
            android:textSize="12sp"
            android:textColor="#008000"
            android:layout_marginTop="6dp"/>

        <TextView
            android:id="@+id/titlePost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nhặt được ví Q.T Ngọc Ánh (2k5,...)"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>

        <!-- Mô tả ngắn -->
        <TextView
            android:id="@+id/shortDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nhặt được Ví + Giấy tờ của Q.T.Ngọc Ánh (2k5, Hà Nam)..."
            android:textSize="13sp"
            android:textColor="#444444"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>

        <!-- Thông tin thêm (thời gian, sđt, nơi, vai trò) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvTimeAgo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕒 45 ngày trước"
                android:textSize="13sp"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/tvContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 0896992096"
                android:textSize="13sp"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Hưng Yên"
                android:textSize="13sp"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 Quản trị viên"
                android:textSize="13sp"
                android:textColor="#333333"/>
        </LinearLayout>

        <!-- Ngày + nút xem -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvPostDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 2024-12-04"
                android:textSize="12sp"
                android:textColor="#444444"/>
            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvViewDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem Chi Tiết"
                android:layout_gravity="right"
                android:textColor="#00B874"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
