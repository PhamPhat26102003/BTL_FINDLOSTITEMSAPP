<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    app:cardElevation="6dp"
    app:cardCornerRadius="12dp"
    android:backgroundTint="#F8F8F8"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:animateLayoutChanges="true">

        <!-- Breadcrumb -->
        <LinearLayout
            android:id="@+id/breadcrumbContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- "Trang chủ /" cố định -->
            <TextView
                android:id="@+id/tvBreadcrumbPrefix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trang chủ /"
                android:textSize="16dp"
                android:textColor="@color/banner_background_green" />

            <!-- Tên bài viết - set động -->
            <TextView
                android:id="@+id/tvBreadcrumbTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhặt dc ví Hoàng Sơn 2k6 ở TP.HCM"
                android:textSize="14sp"
                android:textColor="#555555"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>


        <!-- Tiêu đề bài viết -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/textTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:layout_marginTop="25dp"
                    android:text="Nhặt dc ví Hoàng Sơn 2k6 ở TP.HCM"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="4dp" />

                <!-- Tag "Tin quan trọng" -->
                <TextView
                    android:id="@+id/textImportantTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tin quan trọng"
                    android:layout_marginLeft="26dp"
                    android:layout_marginTop="10dp"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_highlight_tag"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="8dp" />

                <!-- Ngày, lượt xem, người đăng -->
                <LinearLayout
                    android:id="@+id/metaContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical">

                    <!-- Ngày đăng -->
                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅 2024-12-04"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <!-- Dấu cách + icon lượt xem -->
                    <TextView
                        android:id="@+id/tvViewCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="👁 84 lượt xem"
                        android:textSize="13sp"
                        android:textColor="#888888" />

                    <!-- Dấu cách + icon người đăng -->
                    <TextView
                        android:id="@+id/tvAuthor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="👤 Quản trị viên"
                        android:textSize="13sp"
                        android:textColor="#888888" />
                </LinearLayout>

                <!-- Ảnh bài viết -->
                <ImageView
                    android:id="@+id/imgPost"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="8dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/minhhoa" />

                <!-- Nội dung bài viết -->
                <TextView
                    android:id="@+id/tvContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="5dp"
                    android:layout_marginTop="5dp"
                    android:text="Mình làm rơi điện thoại iPhone 13 tại công viên X.Nếu ai nhặt được xin liên hệ lại giúp."
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:layout_marginBottom="12dp" />

                <!-- Nút Nhặt được đồ -->
                <TextView
                    android:id="@+id/tvClaim"
                    android:layout_width="110dp"
                    android:layout_height="30dp"
                    android:text="Nhặt được đồ"
                    android:gravity="center"
                    android:background="@drawable/bg_highlight_tag"
                    android:layout_marginLeft="10dp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/banner_background_green"
                    android:layout_marginBottom="16dp" />
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Địa điểm -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/baseline_location_on_24"
                    android:layout_marginEnd="8dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Địa điểm:"
                        android:textSize="18dp"
                        android:textStyle="bold"
                        android:textColor="#000000" />

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hồ Chí Minh"
                        android:layout_marginTop="3dp"
                        android:textSize="16sp"
                        android:textColor="#000000" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- Số điện thoại -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/baseline_local_phone_24"
                    android:layout_marginEnd="8dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số điện thoại:"
                        android:textSize="18dp"
                        android:textStyle="bold"
                        android:textColor="#000000" />

                    <TextView
                        android:id="@+id/tvPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0869726196"
                        android:layout_marginTop="3dp"
                        android:textSize="16sp"
                        android:textColor="#000000" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- Chia sẻ mạng xã hội -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="15dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chia sẻ bài viết:"
                android:layout_gravity="center"
                android:textSize="21dp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <Space
                android:layout_width="25dp"
                android:layout_height="match_parent"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <ImageView android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/facebookbig"
                    android:layout_marginEnd="8dp"/>

                <ImageView android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/twiter"
                    android:layout_marginEnd="8dp"/>

                <ImageView android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/telegram"
                    android:layout_marginEnd="8dp"/>

            </LinearLayout>
        </LinearLayout>
        <!-- Tag bài viết (Chip) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:chipSpacing="8dp"
            app:singleLine="false"
            app:selectionRequired="false"
            app:singleSelection="false"/>

    </LinearLayout>
</ScrollView>
