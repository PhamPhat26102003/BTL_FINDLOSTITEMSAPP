<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Breadcrumb -->
        <TextView
            android:id="@+id/textBreadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏠 Trang chủ > Đăng nhập"
            android:layout_gravity="left"
            android:layout_marginTop="18dp"
            android:textSize="18dp"
            android:textColor="#333333"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chào mừng đến với cộng \nđồng chia sẻ và tìm đồ"
            android:textSize="22dp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="18dp"

            android:textColor="#000000"
            android:layout_marginBottom="4dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng kí để được hỗ trợ ngay"
            android:layout_marginTop="18dp"

            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp" />


        <!-- Logged out info (ẩn/hiện tùy logic) -->
        <TextView
            android:id="@+id/textLoggedOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="You have been logged out"
            android:gravity="center"
            android:textSize="16dp"
            android:textColor="#1B5E20"
            android:background="@drawable/bg_logout_card"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            />


        <!-- Register link -->
        <TextView
            android:id="@+id/textRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn chưa có tài khoản ? Đăng kí"
            android:layout_marginTop="5dp"
            android:textColor="#8000FF"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Email -->
        <EditText
            android:id="@+id/editTextEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="abc@gmail.com"
            android:inputType="textEmailAddress"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_edittext"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Password -->
        <EditText
            android:id="@+id/editTextPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập mật khẩu của bạn"
            android:inputType="textPassword"
            android:background="@drawable/bg_edittext"
            android:layout_marginTop="15dp"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Login button -->
        <Button
            style="@style/CustomButton"
            android:id="@+id/btnLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng nhập"
            android:layout_marginTop="1dp"
            android:layout_marginLeft="19dp"
            android:layout_gravity="left"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_gradient"
            android:layout_marginBottom="12dp" />

        <!-- Hoặc -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoặc đăng nhập với"
            android:layout_marginTop="1dp"
            android:textColor="#666666"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <!-- Social buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:layout_marginTop="18dp"
            android:layoutDirection="ltr"
            android:orientation="horizontal">

            <Button
                style="@style/CustomButton"
                android:id="@+id/btnGoogle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_social_google_button"
                android:drawableLeft="@drawable/google"
                android:drawablePadding="8dp"
                android:paddingStart="40dp"
                android:paddingEnd="16dp"
                android:minHeight="48dp"
                android:text="Google"
                android:textColor="#FFFFFF"
                android:gravity="center_vertical"
                android:textSize="14sp" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                style="@style/CustomButton"
                android:id="@+id/btnFacebook"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableLeft="@drawable/facebook_icon"
                android:drawablePadding="8dp"
                android:paddingStart="40dp"
                android:paddingEnd="16dp"
                android:minHeight="48dp"
                android:gravity="center_vertical"
                android:text="Facebook"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_social_facebook_button" />
        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>
</ScrollView>
