<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">
        <!-- Breadcrumb -->
        <TextView
            android:id="@+id/textBreadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏠 Trang chủ > Đăng kí"
            android:layout_gravity="left"
            android:layout_marginTop="18dp"
            android:textSize="18dp"
            android:textColor="#333333"
            android:layout_marginBottom="16dp" />

        <!-- Tiêu đề -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chào mừng đến với cộng \nđồng chia sẻ và tìm đồ"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng kí để được hỗ trợ ngay"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn đã có tài khoản ? Đăng nhập"
            android:textColor="#8000FF"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Form gồm 2 ô trên 1 hàng -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4"
            android:columnOrderPreserved="false"
            android:layout_marginBottom="16dp">

            <!-- Họ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Họ"
                    android:textSize="14sp"
                    android:textColor="#000000" />
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Họ của bạn"
                    android:background="@drawable/bg_edittext"
                    android:padding="12dp" />
            </LinearLayout>

            <!-- Tên -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên"
                    android:textSize="14sp"
                    android:textColor="#000000" />
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tên của bạn"
                    android:background="@drawable/bg_edittext"
                    android:padding="12dp" />
            </LinearLayout>

            <!-- SĐT -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Số điện thoại"
                    android:textSize="14sp"
                    android:textColor="#000000" />
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="(+84) hoặc 0xxx"
                    android:inputType="phone"
                    android:background="@drawable/bg_edittext"
                    android:padding="12dp" />
            </LinearLayout>

            <!-- Địa chỉ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Địa chỉ"
                    android:textSize="14sp"
                    android:textColor="#000000" />
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nhập địa chỉ"
                    android:background="@drawable/bg_edittext"
                    android:padding="12dp" />
            </LinearLayout>
        </GridLayout>

        <!-- Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textSize="14sp"
            android:textColor="#000000" />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="abc@gmail.com"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_edittext"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Mật khẩu -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mật khẩu"
            android:textSize="14sp"
            android:textColor="#000000" />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="********"
            android:inputType="textPassword"
            android:background="@drawable/bg_edittext"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Nhập lại mật khẩu -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nhập lại mật khẩu"
            android:textSize="14sp"
            android:textColor="#000000" />
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="********"
            android:inputType="textPassword"
            android:background="@drawable/bg_edittext"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Nút đăng kí -->
        <Button
            style="@style/CustomButton"
            android:id="@+id/btnRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng kí"
            android:layout_gravity="left"
            android:layout_marginLeft="15dp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_gradient"
            android:layout_marginBottom="12dp" />

        <!-- Hoặc đăng nhập với -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoặc đăng nhập với"
            android:textColor="#666666"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <!-- Social buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <Button
                style="@style/CustomButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Google"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_social_google_button"
                android:drawableLeft="@drawable/google"
                android:drawablePadding="8dp"
                android:paddingStart="40dp"
                android:paddingEnd="16dp" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                style="@style/CustomButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Facebook"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_social_facebook_button"
                android:drawableLeft="@drawable/facebook_icon"
                android:drawablePadding="8dp"
                android:paddingStart="40dp"
                android:paddingEnd="16dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
